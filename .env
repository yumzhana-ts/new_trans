# =========================
# ELASTIC STACK SECURITY
# =========================

ELASTIC_PASSWORD=strongElasticPassword123
KIBANA_PASSWORD=strongKibanaPassword123
LOGSTASH_PASSWORD=strongLogstashPassword123

ELASTICSEARCH_HOSTS=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=kibana_system
ELASTICSEARCH_PASSWORD=strongKibanaPassword123

# =========================
# KIBANA ENCRYPTION SETTINGS
# =========================
# These keys are required for Kibana to encrypt and decrypt internal saved objects.
# Without them, Kibana will generate warnings like:
# FleetEncryptedSavedObjectEncryptionKeyRequired

# Used to encrypt saved objects (dashboards, index patterns, Fleet metadata)
XPACK_ENCRYPTEDSAVEDOBJECTS_ENCRYPTIONKEY=0123456789abcdef0123456789abcdef

# Used for encrypting security-related data (sessions, auth tokens, credentials)
XPACK_SECURITY_ENCRYPTIONKEY=abcdef0123456789abcdef0123456789

# Used for reporting features (PDF reports, screenshots, scheduled reports)
XPACK_REPORTING_ENCRYPTIONKEY=1234567890abcdef1234567890abcdef