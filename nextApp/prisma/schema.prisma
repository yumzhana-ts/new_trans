// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider	= "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

model Users {
  id            Int             @id @default(autoincrement())
  email         String          @unique(map: "uq_users_email") @db.VarChar(255)
  password_hash String          @db.VarChar(255)
  username      String?         @db.VarChar(255)
  role          String?         @db.VarChar(50)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  email_verified_at DateTime?    @db.Timestamp(6) 
  challenges    challenges[]
  daily_stars   daily_stars[]
  email_verification_tokens EmailVerificationToken[]
  group_members group_members[]
  oauth_accounts OAuthAccount[]
  password_reset_tokens PasswordResetToken[]
  sessions      sessions[]
  submissions   submissions[]
  two_factor_credential TwoFactorCredential?
  votes         votes[]

  @@map("users")
}

model challenges {
  id          Int           @id @default(autoincrement())
  group_id    Int
  title       String?       @db.VarChar(255)
  status      String?       @db.VarChar(50)
  winner_id   Int?
  created_at  DateTime?     @default(now()) @db.Timestamp(6)
  updated_at  DateTime?     @db.Timestamp(6)
  groups      groups        @relation(fields: [group_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_challenges_group")
  users       Users?        @relation(fields: [winner_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_challenges_winner")
  daily_stars daily_stars[]
  submissions submissions[]
  votes       votes[]

  @@index([group_id], map: "idx_challenges_group")
  @@index([status], map: "idx_challenges_status")
}

model daily_stars {
  id              Int        @id @default(autoincrement())
  user_id         Int
  challenge_id    Int
  day             Int
  remaining_stars Int?
  updated_at      DateTime?  @default(now()) @db.Timestamp(6)
  challenges      challenges @relation(fields: [challenge_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_daily_stars_challenge")
  users           Users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_daily_stars_user")

  @@unique([user_id, challenge_id, day], map: "uq_daily_stars")
}

model group_members {
  group_id  Int
  user_id   Int
  joined_at DateTime? @default(now()) @db.Timestamp(6)
  groups    groups    @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_group_members_group")
  users     Users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_group_members_user")

  @@id([group_id, user_id])
}

model groups {
  id            Int             @id @default(autoincrement())
  name          String          @db.VarChar(255)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  challenges    challenges[]
  group_members group_members[]
}

model sessions {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token      String?   @unique(map: "uq_sessions_token") @db.VarChar(255)
  expires_at DateTime? @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      Users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sessions_user")

  @@index([user_id], map: "idx_sessions_user")
}
model EmailVerificationToken {
  id          Int       @id @default(autoincrement())
  user_id     Int
  token       String    @unique(map: "uq_email_verification_tokens_token") @db.VarChar(255)
  expires_at  DateTime? @db.Timestamp(6)
  consumed_at DateTime? @db.Timestamp(6)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       Users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_email_verification_tokens_user")

  @@index([user_id], map: "idx_email_verification_tokens_user")
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id          Int       @id @default(autoincrement())
  user_id     Int
  token       String    @unique(map: "uq_password_reset_tokens_token") @db.VarChar(255)
  expires_at  DateTime? @db.Timestamp(6)
  consumed_at DateTime? @db.Timestamp(6)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       Users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_password_reset_tokens_user")

  @@index([user_id], map: "idx_password_reset_tokens_user")
  @@map("password_reset_tokens")
}

model TwoFactorCredential {
  id         Int       @id @default(autoincrement())
  user_id    Int       @unique(map: "uq_two_factor_credentials_user")
  secret     String    @db.VarChar(255)
  enabled_at DateTime? @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      Users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_two_factor_credentials_user")

  @@map("two_factor_credentials")
}

model OAuthAccount {
  id               Int       @id @default(autoincrement())
  user_id          Int
  provider         String    @db.VarChar(100)
  provider_user_id String    @db.VarChar(255)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  users            Users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_oauth_accounts_user")

  @@unique([provider, provider_user_id], map: "uq_oauth_accounts_provider_user")
  @@unique([user_id, provider], map: "uq_oauth_accounts_user_provider")
  @@index([user_id], map: "idx_oauth_accounts_user")
  @@map("oauth_accounts")
}

model submission_photos {
  id            Int         @id @default(autoincrement())
  submission_id Int
  photo_data    Bytes
  content_type  String?     @db.VarChar(100)
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  submissions   submissions @relation(fields: [submission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_photos_submission")

  @@index([submission_id], map: "idx_photos_submission")
}

model submissions {
  id                Int                 @id @default(autoincrement())
  challenge_id      Int
  user_id           Int
  dish_name         String?             @db.VarChar(255)
  description       String?
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  submission_photos submission_photos[]
  challenges        challenges          @relation(fields: [challenge_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_submissions_challenge")
  users             Users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_submissions_user")
  votes             votes[]

  @@unique([challenge_id, user_id], map: "uq_submission_user_challenge")
  @@index([challenge_id], map: "idx_submissions_challenge")
  @@index([user_id], map: "idx_submissions_user")
}

model votes {
  id            Int         @id @default(autoincrement())
  submission_id Int
  voter_id      Int
  challenge_id  Int
  day           Int
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  challenges    challenges  @relation(fields: [challenge_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_votes_challenge")
  submissions   submissions @relation(fields: [submission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_votes_submission")
  users         Users       @relation(fields: [voter_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_votes_voter")

  @@unique([submission_id, voter_id, day], map: "uq_vote_once")
  @@index([challenge_id, day], map: "idx_votes_challenge_day")
  @@index([submission_id], map: "idx_votes_submission")
}
